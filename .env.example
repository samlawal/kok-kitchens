# KOK Kitchens — environment variables
# Copy to .env.local for development, and set the same keys in Vercel for prod.
# "Required" = the site needs it to work; "Optional" = the feature degrades
# gracefully if unset.

# ── Core (required) ─────────────────────────────────────────────────────────
# Neon Postgres connection string. Required for ordering, pricing, hire, admin.
DATABASE_URL=

# Strong admin password guarding /admin and its API routes (upload, pricing,
# availability, hire-admin, orders-status, init). REQUIRED in production — if
# unset in prod, all admin/mutating routes fail closed (deny everything).
ADMIN_PASSWORD=

# Canonical site origin, e.g. https://kokkitchens.com. Used for SEO/canonical
# tags, the sitemap, the Stripe redirect and the Uber tracking webhook.
# Set this in Vercel to the live domain.
NEXT_PUBLIC_SITE_URL=

# ── Email (required for order/enquiry confirmations) ────────────────────────
# Resend API key (re_...). Domain kokkitchens.com is verified in Resend.
RESEND_API_KEY=
# Where owner notifications are sent.
NOTIFICATION_EMAIL=

# ── Push notifications (optional — ntfy.sh) ─────────────────────────────────
# Food order alerts topic.
NTFY_TOPIC=kok-kitchen-orders
# Equipment-hire enquiry alerts topic (kept separate from food orders).
NTFY_HIRE_TOPIC=kok-kitchen-hire

# ── Card payments (required only for card checkout; pay-on-delivery works
#    without these) ──────────────────────────────────────────────────────────
# Live key sk_live_... for go-live (sk_test_... in test mode).
STRIPE_SECRET_KEY=
# Webhook signing secret whsec_... from the Stripe dashboard webhook endpoint.
STRIPE_WEBHOOK_SECRET=

# ── Image uploads (required for admin photo management) ──────────────────────
# Vercel Blob read/write token.
BLOB_READ_WRITE_TOKEN=

# ── Address autofill (optional — checkout still works without it) ────────────
# getAddress.io API key for UK street-address lookup at checkout.
GETADDRESS_API_KEY=

# ── Uber Direct delivery (optional — falls back to a flat £7.99 rate) ────────
UBER_CLIENT_ID=
UBER_CLIENT_SECRET=
UBER_CUSTOMER_ID=
# Optional override; defaults to Uber's standard OAuth endpoint.
UBER_OAUTH_URL=
